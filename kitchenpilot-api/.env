# ─────────────────────────────────────────────
# KitchenPilot AI — Environment Variables
# Copy this file to .env and fill in the values
# ─────────────────────────────────────────────

# ── AI Provider ──────────────────────────────
# Which LLM provider to use for intent classification
AI_PROVIDER=openai

# OpenAI API Key (required for openai-speech, openai-vision, and AI interpretation)
OPENAI_API_KEY=

# OpenAI model to use for intent classification (default: gpt-4o-mini)
AI_MODEL=gpt-4o-mini

# ── Capture: Speech-to-Text ───────────────────
# Available: openai | google
SPEECH_PROVIDER=openai

# ── Capture: OCR ─────────────────────────────
# Available: openai | tesseract | google
OCR_PROVIDER=openai

# ── Application ──────────────────────────────
PORT=3000
NODE_ENV=development

# ── Database (for future phases) ─────────────
# DATABASE_URL=postgresql://user:password@localhost:5432/kitchenpilot
DATABASE_URL=
